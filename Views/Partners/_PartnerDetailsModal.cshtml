@model Insurance.ViewModels.PartnerDetailsViewModel

<div class="modal-header">
    <h5 class="modal-title">
        @Model.FullName
    </h5>

    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<div class="modal-body">
    <h6 class="mb-3">Partner details</h6>

    <dl class="row">
        <dt class="col-sm-4">Full name</dt>
        <dd class="col-sm-8">@Model.FullName</dd>

        <dt class="col-sm-4">Address</dt>
        <dd class="col-sm-8">@Model.Address</dd>

        <dt class="col-sm-4">Partner number</dt>
        <dd class="col-sm-8">@Model.PartnerNumber</dd>

        <dt class="col-sm-4">Croatian PIN</dt>
        <dd class="col-sm-8">@Model.CroatianPIN</dd>

        <dt class="col-sm-4">Partner type</dt>
        <dd class="col-sm-8">@(Model.PartnerTypeID == 1 ? "Personal" : "Legal")</dd>

        <dt class="col-sm-4">Created at UTC</dt>
        <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-sm-4">Created by user</dt>
        <dd class="col-sm-8">@Model.CreatedByUser</dd>

        <dt class="col-sm-4">Is foreign</dt>
        <dd class="col-sm-8">@(Model.IsForeign ? "Yes" : "No")</dd>

        <dt class="col-sm-4">External code</dt>
        <dd class="col-sm-8">@Model.ExternalCode</dd>

        <dt class="col-sm-4">Gender</dt>
        <dd class="col-sm-8">@Model.Gender</dd>
    </dl>

    <hr />

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="mb-0">Policies</h6>

        <div class="text-muted small">
            Count: @Model.PolicyCount | Total: @Model.TotalPolicyAmount.ToString("0.00")
        </div>
    </div>

    @if (Model.Policies.Any())
    {
        <table class="table table-sm table-bordered mb-0">
            <thead class="thead-light">
                <tr>
                    <th>Policy number</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var policy in Model.Policies)
                {
                    <tr>
                        <td>@policy.PolicyNumber</td>
                        <td>@policy.PolicyAmount.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted mb-0">No policies.</p>
    }
</div>